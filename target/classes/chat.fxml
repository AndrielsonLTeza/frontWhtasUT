<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="400.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.client.ChatController">
    <children>
        <ListView fx:id="messageListView" prefHeight="350.0" />
        <HBox>
            <TextField fx:id="messageField" promptText="Digite sua mensagem..." HBox.hgrow="ALWAYS" />
            <Button text="Enviar" onAction="#handleSendMessage" />
        </HBox>
    </children>
</VBox>